{
    "manifest_version": 3,
    "name": "Google Maps Places Scraper",
    "description": "Google Maps Places Scraper by Reiner Jasin",
    "version": "0.1.1",

    "permissions": [
        "activeTab",
        "scripting",
        "downloads"
    ],

    "host_permissions": [
        "https://www.google.com/maps/*"
    ],
    
    "action": {
        "default_popup": "popup.html",
        "default_title": "Google Maps Scraper"
    },
    
    "icons": {
        "16": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    }
}